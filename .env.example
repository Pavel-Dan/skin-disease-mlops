# MLflow
MLFLOW_TRACKING_URI=sqlite:///mlruns/mlflow.db
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000

# MinIO (S3-compatible)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
MLFLOW_BUCKET=mlflow
DATASET_BUCKET=skin-datasets

# Kaggle — https://www.kaggle.com/datasets/ismailpromus/skin-diseases-image-dataset
# Token: Account → Settings → API Tokens → save to ~/.kaggle/access_token
# Or set KAGGLE_API_TOKEN in .env (never commit .env)
KAGGLE_DATASET=ismailpromus/skin-diseases-image-dataset
KAGGLE_API_TOKEN=

# Model
MODEL_ARCH=efficientnet_b3
MODEL_NAME=skin-classifier
MODEL_PATH=models/best_model.pt
TRAIN_EPOCHS=15
TRAIN_BATCH_SIZE=16
TRAIN_LR=3e-4
SKIP_MINIO=false
